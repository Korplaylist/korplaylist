---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { regionGroups } from "../../site.config";
---

<BaseLayout title="지역별 한국여행" description="수도권, 강원, 영남, 호남, 제주 권역별 국내 여행 정보를 정리한 한국여행 가이드입니다." canonical="/regions/">
  <section class="page-shell">
    <p class="eyebrow">Regions</p>
    <h1>지역별 한국여행</h1>
    <p>국내 여행지를 권역별로 나누어 찾을 수 있게 정리했습니다. 먼저 핵심 여행지부터 채우고, 이후 숙소와 맛집 글을 연결합니다.</p>
    <div class="page-copy region-group-list">
      {regionGroups.map((group) => (
        <section class="region-group">
          <h2>{group.name}</h2>
          <div class="filter-grid">
            {group.regions.map((region) => <a href={`/regions/${encodeURIComponent(region)}/`}>{region}</a>)}
          </div>
        </section>
      ))}
    </div>
  </section>
</BaseLayout>
