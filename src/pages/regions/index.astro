---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { regions } from "../../site.config";
---

<BaseLayout title="지역별 여행" description="서울, 부산, 제주, 강릉 등 국내 주요 지역별 여행 정보를 모았습니다." canonical="/regions/">
  <section class="page-shell">
    <p class="eyebrow">Regions</p>
    <h1>지역별 여행</h1>
    <p>국내 주요 여행지를 지역별로 탐색합니다.</p>
    <div class="page-copy filter-grid">
      {regions.map((region) => <a href={`/regions/${encodeURIComponent(region)}/`}>{region}</a>)}
    </div>
  </section>
</BaseLayout>
