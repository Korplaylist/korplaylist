---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PopularCarousel from "../../components/PopularCarousel.astro";
import PostCard from "../../components/PostCard.astro";
import { getPopularPosts, getPostUrl, getPublishedTravelPosts } from "../../lib/travel";
import { localizedCategories, localizedRegions, regionSlugMap } from "../../site.config";

const posts = await getPublishedTravelPosts("ja");
const latest = posts.slice(0, 6);
const popular = getPopularPosts(posts, 6);
const categoryDescriptions = {
  "モデルコース": "日帰り、1泊2日、2泊3日など、実際の移動を想定した韓国旅行ルートを整理します。",
  "観光地": "都市、海、歴史スポット、市場、散策コースなど、旅程に入れやすい場所を紹介します。",
  "グルメ": "市場グルメ、地域料理、食費の目安、観光動線に合わせやすい食事スポットをまとめます。",
  "宿泊": "駅近、海沿い、静かなエリアなど、目的別に宿泊エリアを比較します。",
  "交通準備": "公共交通、車なし旅行、KTX、レンタカー、移動時間の考え方を確認できます。",
  "季節旅行": "春の花、夏の海、秋の紅葉、冬旅行など、季節ごとの韓国旅行を整理します。"
};
const regionItems = localizedRegions.ja.map((label, index) => {
  const koRegion = localizedRegions.ko[index];
  const post = posts.find((item) => item.data.regionSlug === regionSlugMap[koRegion]);
  return { label, href: post ? getPostUrl(post) : "/ja/#regions" };
});
const categoryItems = localizedCategories.ja.map((label, index) => {
  const post = posts.find((item) => item.data.category === label);
  return { label, href: post ? getPostUrl(post) : "/ja/#themes", description: categoryDescriptions[label] };
});
---

<BaseLayout
  title="韓国旅行ガイド"
  description="韓国旅行のコース、観光地、交通、グルメ、宿泊、季節情報を客観的に整理する旅行ガイドです。"
  canonical="/ja/"
  locale="ja"
>
  <PopularCarousel posts={popular} locale="ja" />

  <section class="section">
    <div class="section-head">
      <div>
        <h2>最新の韓国旅行ガイド</h2>
        <p>ルート、費用、交通、宿泊、検索意図に合わせて韓国旅行を準備しやすく整理します。</p>
      </div>
      <a class="button secondary" href="/ja/travel/">すべての記事</a>
    </div>
    <div class="post-grid">
      {latest.map((post) => <PostCard post={post} />)}
    </div>
  </section>

  <section id="regions" class="feature-band">
    <div class="section">
      <div class="section-head">
        <div>
          <h2>地域別の韓国旅行</h2>
          <p>旅行したい都市や道・広域市から、関連するガイドへすぐ移動できます。</p>
        </div>
      </div>
      <div class="filter-grid">
        {regionItems.map((region) => <a href={region.href}>{region.label}</a>)}
      </div>
    </div>
  </section>

  <section id="themes" class="section">
    <div class="section-head">
      <div>
        <h2>テーマ別の韓国旅行</h2>
        <p>モデルコース、観光地、グルメ、宿泊、交通、季節旅行から探せます。</p>
      </div>
    </div>
    <div class="info-grid">
      {categoryItems.map((category) => (
        <a class="info-card" href={category.href}>
          <h3>{category.label}</h3>
          <p>{category.description}</p>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>
