---
import BaseLayout from "../../layouts/BaseLayout.astro";
import AuthorBio from "../../components/AuthorBio.astro";
import PostCard from "../../components/PostCard.astro";
import { getPublishedTravelPosts } from "../../lib/travel";
import { localizedCategories, localizedRegions } from "../../site.config";

const posts = await getPublishedTravelPosts("ja");
---

<BaseLayout
  title="韓国旅行ガイド"
  description="韓国旅行を準備する人のために、観光地、モデルコース、交通、グルメ、宿泊、季節旅行情報を客観的に整理するガイドです。"
  canonical="/ja/"
  locale="ja"
>
  <section class="page-shell">
    <p class="eyebrow">日本語</p>
    <h1>韓国旅行ガイド</h1>
    <div class="page-copy">
      <p>
        韓国プレイリストでは、韓国旅行を準備する旅行者向けに、観光地、モデルコース、交通、グルメ、
        宿泊、季節別の旅行情報を順次整理していきます。
      </p>
      <p>
        まず韓国語の記事を作成し、その後に英語版と日本語版を追加して、関連する記事同士を内部リンクでつなげます。
      </p>
    </div>
  </section>
  <section class="section">
    <div class="section-head">
      <div>
        <h2>最新の韓国旅行ガイド</h2>
        <p>韓国語の企画記事を基準に、検索意図と内部リンクを調整した日本語記事を順次公開します。</p>
      </div>
    </div>
    <div class="post-grid">
      {posts.slice(0, 6).map((post) => <PostCard post={post} />)}
    </div>
  </section>
  <section id="regions" class="section">
    <div class="section-head">
      <div>
        <h2>地域</h2>
        <p>韓国の主要旅行地域から、旅程に合う都市を探せます。</p>
      </div>
    </div>
    <div class="filter-grid">
      {localizedRegions.ja.map((region) => <a href="/ja/#regions">{region}</a>)}
    </div>
  </section>
  <section id="themes" class="section feature-band-inner">
    <div class="section-head">
      <div>
        <h2>テーマ</h2>
        <p>モデルコース、観光地、グルメ、宿泊、交通準備、季節旅行に分けて確認できます。</p>
      </div>
    </div>
    <div class="filter-grid">
      {localizedCategories.ja.map((category) => <a href="/ja/#themes">{category}</a>)}
    </div>
  </section>
  <section id="about" class="section">
    <h2>紹介</h2>
    <p>韓国プレイリストは、ルート、移動時間、交通手段、費用、訪問前に確認したい情報を客観的に整理します。</p>
    <AuthorBio locale="ja" compact />
  </section>
  <section id="contact" class="section">
    <h2>お問い合わせ</h2>
    <p>修正依頼やお問い合わせは korplaylist.hong@gmail.com までお送りください。</p>
  </section>
</BaseLayout>
