---
import BaseLayout from "../../layouts/BaseLayout.astro";
import AuthorBio from "../../components/AuthorBio.astro";
import PostCard from "../../components/PostCard.astro";
import { getPublishedTravelPosts } from "../../lib/travel";
import { localizedCategories, localizedRegions } from "../../site.config";

const posts = await getPublishedTravelPosts("en");
---

<BaseLayout
  title="Korea Travel Guide"
  description="An objective Korea travel guide for routes, destinations, transport, food, stays, and seasonal trip planning."
  canonical="/en/"
  locale="en"
>
  <section class="page-shell">
    <p class="eyebrow">English</p>
    <h1>Korea Travel Guide</h1>
    <div class="page-copy">
      <p>
        Korea Playlist is an objective travel guide for people planning trips in Korea. English guides will cover
        destinations, itineraries, transport, food, stays, and seasonal travel ideas.
      </p>
      <p>
        We publish Korean guides first, then expand English pages with localized search intent and internal links.
      </p>
    </div>
  </section>
  <section class="section">
    <div class="section-head">
      <div>
        <h2>Latest Korea Travel Guides</h2>
        <p>English guides are published after the Korean planning article, with localized search intent and internal links.</p>
      </div>
    </div>
    <div class="post-grid">
      {posts.slice(0, 6).map((post) => <PostCard post={post} />)}
    </div>
  </section>
  <section id="regions" class="section">
    <div class="section-head">
      <div>
        <h2>Regions</h2>
        <p>Start with major Korean travel regions and choose the city that fits your route.</p>
      </div>
    </div>
    <div class="filter-grid">
      {localizedRegions.en.map((region) => <a href="/en/#regions">{region}</a>)}
    </div>
  </section>
  <section id="themes" class="section feature-band-inner">
    <div class="section-head">
      <div>
        <h2>Themes</h2>
        <p>Browse Korea travel information by itinerary, destination, food, stays, transport, and season.</p>
      </div>
    </div>
    <div class="filter-grid">
      {localizedCategories.en.map((category) => <a href="/en/#themes">{category}</a>)}
    </div>
  </section>
  <section id="about" class="section">
    <h2>About</h2>
    <p>Korea Playlist focuses on practical planning: routes, timing, transport choices, costs, and things to check before visiting.</p>
    <AuthorBio locale="en" compact />
  </section>
  <section id="contact" class="section">
    <h2>Contact</h2>
    <p>For corrections or partnership inquiries, contact us at korplaylist.hong@gmail.com.</p>
  </section>
</BaseLayout>
