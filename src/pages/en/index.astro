---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PopularCarousel from "../../components/PopularCarousel.astro";
import PostCard from "../../components/PostCard.astro";
import { getPopularPosts, getPostUrl, getPublishedTravelPosts } from "../../lib/travel";
import { localizedCategories, localizedRegions, regionSlugMap } from "../../site.config";

const posts = await getPublishedTravelPosts("en");
const latest = posts.slice(0, 6);
const popular = getPopularPosts(posts, 6);
const categoryDescriptions = {
  Itineraries: "Day trips, two-day routes, and three-day Korea travel plans arranged by realistic movement.",
  Destinations: "Major Korean cities, coastal areas, historic sites, markets, and places worth adding to a route.",
  Food: "Market routes, local dishes, meal budgets, and food stops that fit naturally into travel days.",
  Stays: "Where to stay by city, station access, beach areas, quiet neighborhoods, and itinerary style.",
  Transport: "Public transport, car-free travel, KTX access, rental car checks, and route planning basics.",
  "Seasonal Trips": "Spring flowers, summer beaches, autumn foliage, winter trips, and seasonal Korea travel ideas."
};
const regionItems = localizedRegions.en.map((label, index) => {
  const koRegion = localizedRegions.ko[index];
  const post = posts.find((item) => item.data.regionSlug === regionSlugMap[koRegion]);
  return { label, href: post ? getPostUrl(post) : "/en/#regions" };
});
const categoryItems = localizedCategories.en.map((label, index) => {
  const post = posts.find((item) => item.data.category === label);
  return { label, href: post ? getPostUrl(post) : "/en/#themes", description: categoryDescriptions[label] };
});
---

<BaseLayout
  title="Korea Travel Guide"
  description="An objective Korea travel guide for routes, destinations, transport, food, stays, and seasonal trip planning."
  canonical="/en/"
  locale="en"
>
  <PopularCarousel posts={popular} locale="en" />

  <section class="section">
    <div class="section-head">
      <div>
        <h2>Latest Korea Travel Guides</h2>
        <p>Practical Korea travel articles written around routes, costs, transport, stays, and search intent.</p>
      </div>
      <a class="button secondary" href="/en/travel/">All guides</a>
    </div>
    <div class="post-grid">
      {latest.map((post) => <PostCard post={post} />)}
    </div>
  </section>

  <section id="regions" class="feature-band">
    <div class="section">
      <div class="section-head">
        <div>
          <h2>Korea Travel by Region</h2>
          <p>Start from the province or city that best matches your trip and jump into a relevant guide.</p>
        </div>
      </div>
      <div class="filter-grid">
        {regionItems.map((region) => <a href={region.href}>{region.label}</a>)}
      </div>
    </div>
  </section>

  <section id="themes" class="section">
    <div class="section-head">
      <div>
        <h2>Korea Travel by Theme</h2>
        <p>Choose guides by itinerary, destination, food, stay location, transport, and seasonal timing.</p>
      </div>
    </div>
    <div class="info-grid">
      {categoryItems.map((category) => (
        <a class="info-card" href={category.href}>
          <h3>{category.label}</h3>
          <p>{category.description}</p>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>
