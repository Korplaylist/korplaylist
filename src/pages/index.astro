---
import BaseLayout from "../layouts/BaseLayout.astro";
import PopularCarousel from "../components/PopularCarousel.astro";
import PostCard from "../components/PostCard.astro";
import { categories, categoryDescriptions, regions, siteConfig } from "../site.config";
import { getCategoryUrl, getPopularPosts, getPostRegion, getPublishedTravelPosts, getRegionUrl } from "../lib/travel";

const posts = await getPublishedTravelPosts();
const latest = posts.slice(0, 6);
const popular = getPopularPosts(posts, 6);
const regionList = [...new Set([...regions, ...posts.map((post) => getPostRegion(post))])];
const categoryList = [...new Set([...categories, ...posts.map((post) => post.data.category)])];
---

<BaseLayout title={siteConfig.siteName} description={siteConfig.description}>
  <PopularCarousel posts={popular} locale="ko" />

  <section class="section">
    <div class="section-head">
      <div>
        <h2>최신 여행 가이드</h2>
        <p>국내 여행 코스, 교통, 비용, 숙소 위치를 실제 일정 기준으로 정리했습니다.</p>
      </div>
      <a class="button secondary" href="/travel/">전체 글</a>
    </div>
    <div class="post-grid">
      {latest.map((post) => <PostCard post={post} />)}
    </div>
  </section>

  <section class="feature-band">
    <div class="section">
      <div class="section-head">
        <div>
          <h2>지역별 한국여행</h2>
          <p>서울, 부산, 제주 등 주요 지역별 여행 코스와 준비 정보를 모았습니다.</p>
        </div>
      </div>
      <div class="filter-grid">
        {regionList.map((region) => <a href={getRegionUrl(region)}>{region}</a>)}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="section-head">
      <div>
        <h2>테마별 한국여행</h2>
        <p>여행 코스, 여행지, 맛집, 숙소, 교통, 계절 여행을 주제별로 모았습니다.</p>
      </div>
    </div>
    <div class="info-grid">
      {categoryList.map((category) => (
        <a class="info-card" href={getCategoryUrl(category)}>
          <h3>{category}</h3>
          <p>{categoryDescriptions[category] ?? `${category} 관련 한국여행 정보를 모아 정리합니다.`}</p>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>
