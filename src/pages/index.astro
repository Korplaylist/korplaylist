---
import BaseLayout from "../layouts/BaseLayout.astro";
import PostCard from "../components/PostCard.astro";
import { categories, regions, siteConfig } from "../site.config";
import { getPublishedTravelPosts } from "../lib/travel";

const posts = await getPublishedTravelPosts();
const latest = posts.slice(0, 6);
---

<BaseLayout title={siteConfig.siteName} description={siteConfig.description}>
  <section class="hero">
    <div>
      <p class="eyebrow">국내여행 준비를 위한 빠른 기준점</p>
      <h1>한국여행 코스와 비용을 한눈에 정리합니다</h1>
      <p>
        한국플레이리스트는 지역별 핵심 여행지, 당일치기 동선, 1박2일 일정, 교통과 예산 정보를 객관적으로 정리하는 한국여행 가이드입니다.
      </p>
      <div class="hero-actions">
        <a class="button" href="/regions/">지역별 보기</a>
        <a class="button secondary" href="/categories/">테마별 보기</a>
      </div>
    </div>
    <img src="/images/hero-korea-travel.png" alt="한국 여행지를 상징하는 지도와 도시 풍경 이미지" width="1200" height="760" loading="eager" />
  </section>

  <section class="section">
    <div class="section-head">
      <div>
        <h2>최신 여행 가이드</h2>
        <p>승인 목적에 맞춰 짧은 요약보다 실제 여행 준비에 도움이 되는 정보 구조로 작성합니다.</p>
      </div>
      <a class="button secondary" href="/travel/">전체 글</a>
    </div>
    <div class="post-grid">
      {latest.map((post) => <PostCard post={post} />)}
    </div>
  </section>

  <section class="feature-band">
    <div class="section">
      <div class="section-head">
        <div>
          <h2>지역별 여행</h2>
          <p>처음 방문하는 사람도 동선을 빠르게 잡을 수 있도록 지역별 글을 묶었습니다.</p>
        </div>
      </div>
      <div class="filter-grid">
        {regions.map((region) => <a href={`/regions/${encodeURIComponent(region)}/`}>{region}</a>)}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="section-head">
      <div>
        <h2>테마별 보기</h2>
        <p>당일치기, 1박2일, 비용, 계절 여행처럼 검색 의도에 맞춰 탐색할 수 있습니다.</p>
      </div>
    </div>
    <div class="info-grid">
      {categories.map((category) => (
        <a class="info-card" href={`/categories/${encodeURIComponent(category)}/`}>
          <h3>{category}</h3>
          <p>{category}에 맞는 국내여행 정보를 모아봅니다.</p>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>
