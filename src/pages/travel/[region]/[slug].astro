---
import { getCollection } from "astro:content";
import PostLayout from "../../../layouts/PostLayout.astro";
import { extractFaqItems, getPostRegion, getRegionSlug, getRelatedPosts } from "../../../lib/travel";

export async function getStaticPaths() {
  const posts = await getCollection("travel", ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { region: getRegionSlug(getPostRegion(post)), slug: post.slug },
    props: { post }
  }));
}

const { post } = Astro.props;
const allPosts = await getCollection("travel", ({ data }) => !data.draft);
const { Content, headings } = await post.render();
const relatedPosts = getRelatedPosts(post, allPosts, 5);
const faqItems = extractFaqItems(post.body);
---

<PostLayout post={post} headings={headings} relatedPosts={relatedPosts} faqItems={faqItems}>
  <Content />
</PostLayout>
