---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PostCard from "../../components/PostCard.astro";
import { getPublishedTravelPosts } from "../../lib/travel";

const posts = await getPublishedTravelPosts();
---

<BaseLayout title="전체 여행 글" description="한국플레이리스트의 국내여행 가이드 전체 글입니다." canonical="/travel/">
  <section class="page-shell">
    <p class="eyebrow">Travel Guides</p>
    <h1>전체 여행 글</h1>
    <p>지역, 일정, 비용, 계절 정보를 기준으로 국내여행 준비에 필요한 글을 모았습니다.</p>
  </section>
  <section class="section">
    <div class="post-grid">
      {posts.map((post) => <PostCard post={post} />)}
    </div>
  </section>
</BaseLayout>
