---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PostCard from "../../components/PostCard.astro";
import { getCategorySlug, getCategoryUrl, getPublishedTravelPosts } from "../../lib/travel";
import { categories, categoryDescriptions } from "../../site.config";

export async function getStaticPaths() {
  const posts = await getPublishedTravelPosts();
  const allCategories = [...new Set([...categories, ...posts.map((post) => post.data.category)])];
  return allCategories.map((category) => ({ params: { category: getCategorySlug(category) }, props: { category } }));
}

const { category } = Astro.props;
const posts = (await getPublishedTravelPosts()).filter((post) => post.data.category === category);
const description = categoryDescriptions[category] ?? `${category} 한국여행 정보를 모았습니다.`;
---

<BaseLayout title={category} description={description} canonical={getCategoryUrl(category)}>
  <section class="page-shell">
    <p class="eyebrow">Category</p>
    <h1>{category}</h1>
    <p>{description}</p>
  </section>
  <section class="section">
    {posts.length > 0 ? (
      <div class="post-grid">
        {posts.map((post) => <PostCard post={post} />)}
      </div>
    ) : (
      <div class="empty-state">
        <strong>준비 중인 테마입니다</strong>
        <p>이 분류는 향후 숙소 위치, 지역별 맛집, 여행 준비 글처럼 별도 콘텐츠를 확장할 때 우선 채워갈 예정입니다.</p>
      </div>
    )}
  </section>
</BaseLayout>
