---
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { siteConfig } from "../site.config";
import globalStyles from "../styles/global.css?raw";

const {
  title = siteConfig.siteName,
  description = siteConfig.description,
  canonical = Astro.url.pathname,
  image = "/images/hero-korea-travel.png",
  type = "website",
  locale = "ko",
  keywords = "",
  alternates = {},
  jsonLd
} = Astro.props;

const absoluteUrl = new URL(canonical, siteConfig.domain).toString();
const absoluteImage = new URL(image, siteConfig.domain).toString();
const localizedSiteName = siteConfig.localizedSiteNames[locale] ?? siteConfig.siteName;
const pageTitle = title === localizedSiteName || title === siteConfig.siteName ? title : `${title} | ${localizedSiteName}`;
const ogLocales: Record<string, string> = {
  ko: "ko_KR",
  en: "en_US",
  ja: "ja_JP"
};
const htmlLangs: Record<string, string> = {
  ko: "ko",
  en: "en",
  ja: "ja"
};
const homeAlternates = {
  ko: new URL("/", siteConfig.domain).toString(),
  en: new URL("/en/", siteConfig.domain).toString(),
  ja: new URL("/ja/", siteConfig.domain).toString(),
  "x-default": new URL("/", siteConfig.domain).toString()
};
const shouldRenderHomeAlternates = ["/", "/en/", "/ja/"].includes(new URL(absoluteUrl).pathname);
const alternateEntries = Object.entries(alternates);
---

<!doctype html>
<html lang={htmlLangs[locale] ?? "ko"}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow, max-image-preview:large" />
    {keywords && <meta name="keywords" content={keywords} />}
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="apple-touch-icon" href="/brand/apple-touch-icon.png" />
    <link rel="canonical" href={absoluteUrl} />
    <meta property="og:locale" content={ogLocales[locale] ?? "ko_KR"} />
    <meta property="og:type" content={type} />
    <meta property="og:site_name" content={localizedSiteName} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={absoluteUrl} />
    <meta property="og:image" content={absoluteImage} />
    <meta property="og:image:alt" content={title} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={absoluteImage} />
    {shouldRenderHomeAlternates && Object.entries(homeAlternates).map(([hreflang, href]) => (
      <link rel="alternate" hreflang={hreflang} href={href} />
    ))}
    {!shouldRenderHomeAlternates && alternateEntries.map(([hreflang, href]) => (
      <link rel="alternate" hreflang={hreflang} href={href as string} />
    ))}
    {siteConfig.googleSiteVerification && <meta name="google-site-verification" content={siteConfig.googleSiteVerification} />}
    {siteConfig.naverSiteVerification && <meta name="naver-site-verification" content={siteConfig.naverSiteVerification} />}
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Organization",
      name: localizedSiteName,
      url: siteConfig.domain,
      logo: new URL("/brand/korplaylist-logo-38.png", siteConfig.domain).toString()
    })} />
    {jsonLd && <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />}
    <style set:html={globalStyles} />
  </head>
  <body>
    <Header locale={locale} />
    <main>
      <slot />
    </main>
    <Footer locale={locale} />
  </body>
</html>
