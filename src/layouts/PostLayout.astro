---
import BaseLayout from "./BaseLayout.astro";
import AuthorBio from "../components/AuthorBio.astro";
import RelatedPosts from "../components/RelatedPosts.astro";
import ShareButtons from "../components/ShareButtons.astro";
import StayRecommendationPanel from "../components/StayRecommendationPanel.astro";
import { authorProfiles, siteConfig } from "../site.config";
import { getWebpSrcSet } from "../lib/imageVariants";
import { formatDate, getImageAlt, getPostLocale, getPostRegion, getPostUrl, getRegionUrl } from "../lib/travel";

const { post, headings = [], relatedPosts = [], faqItems = [], alternates = {} } = Astro.props;
const postUrl = new URL(getPostUrl(post), siteConfig.domain).toString();
const postImage = new URL(post.data.heroImage, siteConfig.domain).toString();
const locale = getPostLocale(post);
const author = authorProfiles[locale] ?? authorProfiles.ko;
const imageAlt = getImageAlt(post);
const postRegion = getPostRegion(post);
const regionUrl = locale === "ko" ? getRegionUrl(postRegion) : `/${locale}/#regions`;
const labels = {
  ko: {
    home: "홈",
    homeUrl: "/",
    breadcrumb: "현재 위치",
    author: "작성자",
    published: "게시일",
    updated: "업데이트",
    tags: "태그",
    toc: "목차"
  },
  en: {
    home: "Home",
    homeUrl: "/en/",
    breadcrumb: "Breadcrumb",
    author: "Author",
    published: "Published",
    updated: "Updated",
    tags: "Tags",
    toc: "Contents"
  },
  ja: {
    home: "ホーム",
    homeUrl: "/ja/",
    breadcrumb: "現在位置",
    author: "執筆者",
    published: "公開日",
    updated: "更新日",
    tags: "タグ",
    toc: "目次"
  }
}[locale] ?? {
  home: "홈",
  homeUrl: "/",
  breadcrumb: "현재 위치",
  author: "작성자",
  published: "게시일",
  updated: "업데이트",
  tags: "태그",
  toc: "목차"
};
const articleSchema = {
  "@type": "Article",
  headline: post.data.title,
  description: post.data.description,
  image: postImage,
  datePublished: post.data.publishedAt.toISOString(),
  dateModified: post.data.updatedAt.toISOString(),
  keywords: post.data.tags.join(", "),
  author: {
    "@type": "Person",
    name: author.name,
    description: `${author.summary} ${author.detail}`,
    url: new URL(locale === "ko" ? "/about/" : `/${locale}/#about`, siteConfig.domain).toString()
  },
  publisher: {
    "@type": "Organization",
    name: siteConfig.siteName,
    url: siteConfig.domain
  },
  mainEntityOfPage: postUrl
};
const breadcrumbSchema = {
  "@type": "BreadcrumbList",
  itemListElement: [
    {
      "@type": "ListItem",
      position: 1,
      name: labels.home,
      item: new URL(labels.homeUrl, siteConfig.domain).toString()
    },
    {
      "@type": "ListItem",
      position: 2,
      name: postRegion,
      item: new URL(regionUrl, siteConfig.domain).toString()
    },
    {
      "@type": "ListItem",
      position: 3,
      name: post.data.title,
      item: postUrl
    }
  ]
};
const faqSchema = faqItems.length
  ? {
      "@type": "FAQPage",
      mainEntity: faqItems.map((item) => ({
        "@type": "Question",
        name: item.question,
        acceptedAnswer: {
          "@type": "Answer",
          text: item.answer
        }
      }))
    }
  : null;
const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [articleSchema, breadcrumbSchema, ...(faqSchema ? [faqSchema] : [])]
};
---

<BaseLayout
  title={post.data.title}
  description={post.data.description}
  canonical={getPostUrl(post)}
  image={post.data.heroImage}
  type="article"
  keywords={post.data.tags.join(", ")}
  locale={locale}
  alternates={alternates}
  jsonLd={jsonLd}
>
  <article class="article-shell">
    <nav class="breadcrumb" aria-label={labels.breadcrumb}>
      <a href={labels.homeUrl}>{labels.home}</a>
      <span>/</span>
      <a href={regionUrl}>{postRegion}</a>
      <span>/</span>
      <span>{post.data.title}</span>
    </nav>
    <header class="article-header">
      <p class="meta">{post.data.region} · {post.data.category}</p>
      <h1>{post.data.title}</h1>
      <p>{post.data.description}</p>
      <dl class="article-facts">
        <div><dt>{labels.author}</dt><dd>{author.name}</dd></div>
        <div><dt>{labels.published}</dt><dd>{formatDate(post.data.publishedAt, locale)}</dd></div>
        <div><dt>{labels.updated}</dt><dd>{formatDate(post.data.updatedAt, locale)}</dd></div>
        <div><dt>{labels.tags}</dt><dd>{post.data.tags.join(", ")}</dd></div>
      </dl>
      <figure class="article-hero-figure">
        <picture>
          <source type="image/webp" srcset={getWebpSrcSet(post.data.heroImage, [480, 520, 640, 680, 768, 960])} sizes="(max-width: 860px) calc(100vw - 36px), 792px" />
          <img src={post.data.heroImage} alt={imageAlt} width="1200" height="630" loading="eager" decoding="async" fetchpriority="high" sizes="(max-width: 860px) calc(100vw - 36px), 792px" />
        </picture>
        {post.data.imageCredit && <figcaption>{post.data.imageCredit}</figcaption>}
      </figure>
    </header>
    {headings.length > 0 && (
      <aside class="toc" aria-label={labels.toc}>
        <strong>{labels.toc}</strong>
        <ol>
          {headings.filter((heading) => heading.depth === 2).map((heading) => (
            <li><a href={`#${heading.slug}`}>{heading.text}</a></li>
          ))}
        </ol>
      </aside>
    )}
    <div class="article-content">
      <slot />
    </div>
    <AuthorBio locale={locale} />
    <ShareButtons title={post.data.title} description={post.data.description} url={postUrl} image={postImage} locale={locale} />
    <StayRecommendationPanel post={post} locale={locale} />
    <RelatedPosts posts={relatedPosts} locale={locale} />
  </article>
</BaseLayout>
