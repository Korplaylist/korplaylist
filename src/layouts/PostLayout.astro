---
import BaseLayout from "./BaseLayout.astro";
import AuthorBio from "../components/AuthorBio.astro";
import InternalLinkGuide from "../components/InternalLinkGuide.astro";
import RelatedPosts from "../components/RelatedPosts.astro";
import ShareButtons from "../components/ShareButtons.astro";
import StayRecommendationPanel from "../components/StayRecommendationPanel.astro";
import { authorProfiles, siteConfig } from "../site.config";
import { formatDate, getImageAlt, getPostRegion, getPostUrl, getRegionUrl } from "../lib/travel";

const { post, headings = [], relatedPosts = [], faqItems = [] } = Astro.props;
const postUrl = new URL(getPostUrl(post), siteConfig.domain).toString();
const postImage = new URL(post.data.heroImage, siteConfig.domain).toString();
const author = authorProfiles.ko;
const imageAlt = getImageAlt(post);
const postRegion = getPostRegion(post);
const regionUrl = getRegionUrl(postRegion);
const articleSchema = {
  "@type": "Article",
  headline: post.data.title,
  description: post.data.description,
  image: postImage,
  datePublished: post.data.publishedAt.toISOString(),
  dateModified: post.data.updatedAt.toISOString(),
  keywords: post.data.tags.join(", "),
  author: {
    "@type": "Person",
    name: author.name,
    description: `${author.summary} ${author.detail}`,
    url: new URL("/about/", siteConfig.domain).toString()
  },
  publisher: {
    "@type": "Organization",
    name: siteConfig.siteName,
    url: siteConfig.domain
  },
  mainEntityOfPage: postUrl
};
const breadcrumbSchema = {
  "@type": "BreadcrumbList",
  itemListElement: [
    {
      "@type": "ListItem",
      position: 1,
      name: "홈",
      item: siteConfig.domain
    },
    {
      "@type": "ListItem",
      position: 2,
      name: postRegion,
      item: new URL(regionUrl, siteConfig.domain).toString()
    },
    {
      "@type": "ListItem",
      position: 3,
      name: post.data.title,
      item: postUrl
    }
  ]
};
const faqSchema = faqItems.length
  ? {
      "@type": "FAQPage",
      mainEntity: faqItems.map((item) => ({
        "@type": "Question",
        name: item.question,
        acceptedAnswer: {
          "@type": "Answer",
          text: item.answer
        }
      }))
    }
  : null;
const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [articleSchema, breadcrumbSchema, ...(faqSchema ? [faqSchema] : [])]
};
---

<BaseLayout
  title={post.data.title}
  description={post.data.description}
  canonical={getPostUrl(post)}
  image={post.data.heroImage}
  type="article"
  keywords={post.data.tags.join(", ")}
  jsonLd={jsonLd}
>
  <article class="article-shell">
    <nav class="breadcrumb" aria-label="현재 위치">
      <a href="/">홈</a>
      <span>/</span>
      <a href={regionUrl}>{postRegion}</a>
      <span>/</span>
      <span>{post.data.title}</span>
    </nav>
    <header class="article-header">
      <p class="meta">{post.data.region} · {post.data.category}</p>
      <h1>{post.data.title}</h1>
      <p>{post.data.description}</p>
      <dl class="article-facts">
        <div><dt>작성자</dt><dd>{author.name}</dd></div>
        <div><dt>게시일</dt><dd>{formatDate(post.data.publishedAt)}</dd></div>
        <div><dt>업데이트</dt><dd>{formatDate(post.data.updatedAt)}</dd></div>
        <div><dt>태그</dt><dd>{post.data.tags.join(", ")}</dd></div>
      </dl>
      <figure class="article-hero-figure">
        <img src={post.data.heroImage} alt={imageAlt} width="1200" height="630" loading="eager" decoding="async" fetchpriority="high" />
        {post.data.imageCredit && <figcaption>{post.data.imageCredit}</figcaption>}
      </figure>
    </header>
    {headings.length > 0 && (
      <aside class="toc" aria-label="글 목차">
        <strong>목차</strong>
        <ol>
          {headings.filter((heading) => heading.depth === 2).map((heading) => (
            <li><a href={`#${heading.slug}`}>{heading.text}</a></li>
          ))}
        </ol>
      </aside>
    )}
    <div class="article-content">
      <slot />
    </div>
    <InternalLinkGuide currentPost={post} posts={relatedPosts} />
    <AuthorBio locale="ko" />
    <ShareButtons title={post.data.title} description={post.data.description} url={postUrl} image={postImage} />
    <StayRecommendationPanel post={post} />
    <RelatedPosts posts={relatedPosts} />
  </article>
</BaseLayout>
