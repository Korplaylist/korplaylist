---
import { getWebpSrcSet } from "../lib/imageVariants";
import { getImageAlt, getPostLocale, getPostUrl, formatDate } from "../lib/travel";

const { post } = Astro.props;
const locale = getPostLocale(post);
const readLabel = locale === "en" ? "Read" : locale === "ja" ? "読む" : "읽기";
---

<article class="post-card">
  <a href={getPostUrl(post)} class="post-image-link" aria-label={`${post.data.title} ${readLabel}`}>
    <picture>
      <source type="image/webp" srcset={getWebpSrcSet(post.data.heroImage, [320, 330, 360, 480])} sizes="(max-width: 760px) calc(100vw - 36px), 330px" />
      <img src={post.data.heroImage} alt={getImageAlt(post)} width="480" height="300" loading="lazy" decoding="async" sizes="(max-width: 760px) calc(100vw - 36px), 330px" />
    </picture>
  </a>
  <div class="post-card-body">
    <p class="meta">{post.data.region} · {post.data.category} · {formatDate(post.data.updatedAt, locale)}</p>
    <h2><a href={getPostUrl(post)}>{post.data.title}</a></h2>
    <p>{post.data.description}</p>
    <div class="tag-list">
      {post.data.tags.slice(0, 3).map((tag) => <span>{tag}</span>)}
    </div>
  </div>
</article>
