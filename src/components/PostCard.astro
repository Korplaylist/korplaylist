---
import { getPostUrl, formatDate } from "../lib/travel";

const { post } = Astro.props;
---

<article class="post-card">
  <a href={getPostUrl(post)} class="post-image-link" aria-label={`${post.data.title} 읽기`}>
    <img src={post.data.heroImage} alt="" width="640" height="420" loading="lazy" />
  </a>
  <div class="post-card-body">
    <p class="meta">{post.data.region} · {post.data.category} · {formatDate(post.data.updatedAt)}</p>
    <h2><a href={getPostUrl(post)}>{post.data.title}</a></h2>
    <p>{post.data.description}</p>
    <div class="tag-list">
      {post.data.tags.slice(0, 3).map((tag) => <span>{tag}</span>)}
    </div>
  </div>
</article>
