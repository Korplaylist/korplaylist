---
import { getPostUrl } from "../lib/travel";

const { currentPost, posts = [] } = Astro.props;
const links = posts.slice(0, 3);
---

{links.length > 0 && (
  <aside class="internal-link-guide" aria-labelledby="internal-links-title">
    <p class="eyebrow">내부 링크</p>
    <h2 id="internal-links-title">{currentPost.data.region} 여행을 더 구체적으로 준비하려면</h2>
    <p>
      이 글을 본 뒤에는 아래 가이드를 함께 확인하면 동선, 비용, 교통, 먹거리 정보를 한 번에 이어서 정리할 수 있습니다.
    </p>
    <div>
      {links.map((post) => (
        <a href={getPostUrl(post)}>
          <span>{post.data.region} · {post.data.category}</span>
          <strong>{post.data.title}</strong>
        </a>
      ))}
    </div>
  </aside>
)}
