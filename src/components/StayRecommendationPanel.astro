---
import staysByRegion from "../data/myrealtrip-stays.json";

const { post, locale = "ko" } = Astro.props;
const regionBySlug = {
  seoul: "서울",
  busan: "부산",
  daegu: "대구",
  incheon: "인천",
  jeju: "제주",
  gangwon: "강릉",
  jeonbuk: "전주",
  gyeongbuk: "경주",
  jeonnam: "여수",
  gyeongnam: "통영"
};
const stayRegionKeywords = {
  seoul: "서울",
  busan: "부산",
  jeju: "제주",
  gangneung: "강릉",
  sokcho: "속초",
  chuncheon: "춘천",
  jeonju: "전주",
  gyeongju: "경주",
  yeosu: "여수",
  tongyeong: "통영",
  incheon: "인천",
  daegu: "대구"
};
const routeKey = `${post.data.translationKey ?? ""} ${post.data.urlSlug ?? ""}`.toLowerCase();
const matchedStayRegion = Object.entries(stayRegionKeywords).find(([keyword]) => routeKey.includes(keyword))?.[1];
const stayRegion = staysByRegion[post.data.region] ? post.data.region : matchedStayRegion ?? regionBySlug[post.data.regionSlug] ?? post.data.region;
const fallbackStayRegion = {
  경주: "부산",
  여수: "부산",
  속초: "강릉",
  통영: "부산",
  인천: "서울",
  대구: "부산",
  춘천: "강릉"
};
const exactStays = staysByRegion[stayRegion] ?? [];
const recommendationRegion = exactStays.length > 0 ? stayRegion : fallbackStayRegion[stayRegion] ?? stayRegion;
const stays = exactStays.length > 0 ? exactStays : staysByRegion[recommendationRegion] ?? [];
const usesFallbackRegion = exactStays.length === 0 && recommendationRegion !== stayRegion && stays.length > 0;
const regionLabels = {
  ko: {
    서울: "서울",
    부산: "부산",
    제주: "제주",
    강릉: "강릉",
    전주: "전주",
    경주: "경주",
    여수: "여수",
    속초: "속초",
    통영: "통영",
    인천: "인천",
    대구: "대구",
    춘천: "춘천"
  },
  en: {
    서울: "Seoul",
    부산: "Busan",
    제주: "Jeju",
    강릉: "Gangneung",
    전주: "Jeonju",
    경주: "Gyeongju",
    여수: "Yeosu",
    속초: "Sokcho",
    통영: "Tongyeong",
    인천: "Incheon",
    대구: "Daegu",
    춘천: "Chuncheon"
  },
  ja: {
    서울: "ソウル",
    부산: "釜山",
    제주: "済州",
    강릉: "江陵",
    전주: "全州",
    경주: "慶州",
    여수: "麗水",
    속초: "束草",
    통영: "統営",
    인천: "仁川",
    대구: "大邱",
    춘천: "春川"
  }
};
const recommendationRegionLabel = regionLabels[locale]?.[recommendationRegion] ?? recommendationRegion;
const stayRegionLabel = regionLabels[locale]?.[stayRegion] ?? stayRegion;
const localizedStayNames = {
  en: {
    "롯데호텔 월드": "Lotte Hotel World",
    "더글라스 하우스": "Douglas House",
    "안토": "Ahn To",
    "서울신라호텔": "The Shilla Seoul",
    "토요코인 부산역1": "Toyoko Inn Busan Station No.1",
    "그랜드 조선 부산": "Grand Josun Busan",
    "호텔 센트럴베이 광안리": "Hotel Central Bay Gwangalli",
    "윈덤 그랜드 부산": "Wyndham Grand Busan",
    "제주 노블레스 관광 호텔": "Jeju Noblesse Tourist Hotel",
    "제주 오리엔탈 호텔 앤 카지노": "Jeju Oriental Hotel & Casino",
    "제주팔레스관광호텔": "Jeju Palace Tourist Hotel",
    "제주 그라벨 호텔": "Jeju Grabel Hotel",
    "강릉숙소 스테이 북앤타이프": "Gangneung Stay Book & Type",
    "신라모노그램 강릉 레지던스": "Shilla Monogram Gangneung Residence",
    "세인트존스호텔": "St. John's Hotel",
    "신라모노그램 강릉 호텔": "Shilla Monogram Gangneung Hotel",
    "전주 금암동 하운드 전주터미널": "Hound Jeonju Terminal Geumam-dong",
    "글로스터호텔 전주": "Gloucester Hotel Jeonju",
    "베스트 웨스턴 플러스 전주 호텔": "Best Western Plus Jeonju Hotel",
    "라한호텔 전주": "Lahan Hotel Jeonju"
  },
  ja: {
    "롯데호텔 월드": "ロッテホテルワールド",
    "더글라스 하우스": "ダグラスハウス",
    "안토": "アント",
    "서울신라호텔": "ソウル新羅ホテル",
    "토요코인 부산역1": "東横イン釜山駅1",
    "그랜드 조선 부산": "グランドジョスン釜山",
    "호텔 센트럴베이 광안리": "ホテルセントラルベイ広安里",
    "윈덤 그랜드 부산": "ウィンダムグランド釜山",
    "제주 노블레스 관광 호텔": "済州ノブレス観光ホテル",
    "제주 오리엔탈 호텔 앤 카지노": "済州オリエンタルホテル＆カジノ",
    "제주팔레스관광호텔": "済州パレス観光ホテル",
    "제주 그라벨 호텔": "済州グラベルホテル",
    "강릉숙소 스테이 북앤타이프": "江陵ステイ ブック＆タイプ",
    "신라모노그램 강릉 레지던스": "新羅モノグラム江陵レジデンス",
    "세인트존스호텔": "セントジョンズホテル",
    "신라모노그램 강릉 호텔": "新羅モノグラム江陵ホテル",
    "전주 금암동 하운드 전주터미널": "全州金岩洞ハウンド全州ターミナル",
    "글로스터호텔 전주": "グロスターホテル全州",
    "베스트 웨스턴 플러스 전주 호텔": "ベストウェスタンプラス全州ホテル",
    "라한호텔 전주": "ラハンホテル全州"
  }
};
const localizePrice = (price) => {
  if (!price || locale === "ko") return price;
  const amount = price.replace("원/박", "").trim();
  if (locale === "en") return `KRW ${amount} / night`;
  if (locale === "ja") return `${amount}ウォン/泊`;
  return price;
};
const localizeRating = (rating) => {
  if (!rating || locale === "ko") return rating;
  const normalized = rating.replace("⭐", "").trim();
  if (locale === "en") return `Rating ${normalized}`;
  if (locale === "ja") return `評価 ${normalized.replace("(", "（").replace(")", "）")}`;
  return rating;
};
const localizeStay = (stay) => {
  const name = localizedStayNames[locale]?.[stay.name] ?? stay.name;
  return {
    ...stay,
    name,
    price: localizePrice(stay.price),
    rating: localizeRating(stay.rating),
    imageAlt:
      locale === "en"
        ? `${recommendationRegionLabel} recommended stay: ${name}`
        : locale === "ja"
          ? `${recommendationRegionLabel}のおすすめ宿泊先：${name}`
          : stay.imageAlt
  };
};
const localizedStays = stays.map(localizeStay);
const labels = {
  ko: {
    eyebrow: "숙소 추천",
    title: "이 여행 코스와 가까운 숙소 보기",
    description: "마이리얼트립 숙소 검색 결과를 기준으로 이미지, 가격, 평점을 함께 보여드립니다. 이동 전 실제 가격, 객실, 취소 조건은 예약 페이지에서 다시 확인하세요.",
    searchKeyword: `${stayRegion} 숙소`,
    fallbackRating: "평점 정보 확인 필요",
    fallbackPrice: "가격 확인하기",
    emptyTitle: `${post.data.region} 숙소를 마이리얼트립에서 바로 검색하기`,
    emptyText: "현재 자동 추천 결과가 없어 검색 페이지로 연결합니다.",
    fallbackNotice: `현재 ${post.data.region} 직접 숙소 데이터가 부족해 ${recommendationRegionLabel} 권역 숙소를 참고용으로 함께 보여드립니다.`,
    affiliate: "이 영역에는 제휴 링크가 포함될 수 있습니다. 링크를 통해 예약이 발생하면 한국플레이리스트가 일정 수수료를 받을 수 있으며, 이용자에게 추가 비용이 부과되지는 않습니다."
  },
  en: {
    eyebrow: "Stay Recommendations",
    title: "Hotels and stays near this itinerary",
    description: "These cards use MyRealTrip stay listings with photos, prices, and ratings where available. Always confirm the final price, room type, and cancellation policy on the booking page before reserving.",
    searchKeyword: `${stayRegionLabel} hotel stay Korea`,
    fallbackRating: "Check rating details",
    fallbackPrice: "Check price",
    emptyTitle: `Search ${stayRegionLabel} stays on MyRealTrip`,
    emptyText: "No automatic stay matches are available yet, so this link opens the search page.",
    fallbackNotice: `Direct stay data for ${post.data.region} is limited, so nearby ${recommendationRegionLabel} listings are shown as reference options.`,
    affiliate: "This section may include affiliate links. Korea Playlist may receive a commission if you book through these links, at no additional cost to you."
  },
  ja: {
    eyebrow: "宿泊おすすめ",
    title: "この旅行ルートに近い宿泊先を見る",
    description: "マイリアルトリップの宿泊情報をもとに、写真、料金、評価を確認できるカードです。予約前に最終料金、客室条件、キャンセル規定を必ず予約ページで確認してください。",
    searchKeyword: `${stayRegionLabel} ホテル 韓国`,
    fallbackRating: "評価を確認",
    fallbackPrice: "料金を確認",
    emptyTitle: `${stayRegionLabel}の宿泊先をMyRealTripで検索`,
    emptyText: "現在、自動おすすめ結果がないため検索ページへ移動します。",
    fallbackNotice: `${post.data.region}の直接宿泊データが少ないため、近い${recommendationRegionLabel}エリアの宿泊先を参考として表示します。`,
    affiliate: "このエリアにはアフィリエイトリンクが含まれる場合があります。リンク経由で予約が発生すると韓国プレイリストが手数料を受け取ることがありますが、利用者に追加費用はかかりません。"
  }
}[locale] ?? {
  eyebrow: "숙소 추천",
  title: "이 여행 코스와 가까운 숙소 보기",
  description: "마이리얼트립 숙소 검색 결과를 기준으로 이미지, 가격, 평점을 함께 보여드립니다. 이동 전 실제 가격, 객실, 취소 조건은 예약 페이지에서 다시 확인하세요.",
  searchKeyword: `${stayRegion} 숙소`,
  fallbackRating: "평점 정보 확인 필요",
  fallbackPrice: "가격 확인하기",
  emptyTitle: `${post.data.region} 숙소를 마이리얼트립에서 바로 검색하기`,
  emptyText: "현재 자동 추천 결과가 없어 검색 페이지로 연결합니다.",
  fallbackNotice: `현재 ${post.data.region} 직접 숙소 데이터가 부족해 ${recommendationRegionLabel} 권역 숙소를 참고용으로 함께 보여드립니다.`,
  affiliate: "이 영역에는 제휴 링크가 포함될 수 있습니다. 링크를 통해 예약이 발생하면 한국플레이리스트가 일정 수수료를 받을 수 있으며, 이용자에게 추가 비용이 부과되지는 않습니다."
};
const searchUrl = `https://www.myrealtrip.com/search?keyword=${encodeURIComponent(labels.searchKeyword)}`;
---

<aside class:list={["stay-panel", { empty: stays.length === 0 }]} aria-labelledby="stay-recommend-title">
  <div class="stay-panel-head">
    <div>
      <p class="eyebrow">{labels.eyebrow}</p>
      <h2 id="stay-recommend-title">{labels.title}</h2>
      <p>{labels.description}</p>
    </div>
  </div>
  {stays.length > 0 ? (
    <>
    {usesFallbackRegion && <p class="stay-fallback-note">{labels.fallbackNotice}</p>}
    <div class="stay-grid">
      {localizedStays.map((stay) => (
        <a class="stay-card" href={stay.url} target="_blank" rel="sponsored nofollow noopener noreferrer">
          <figure>
            <img src={stay.image} alt={stay.imageAlt} width="420" height="260" loading="lazy" decoding="async" />
            <figcaption>{stay.imageCredit}</figcaption>
          </figure>
          <div>
            <strong>{stay.name}</strong>
            <p>{stay.rating || labels.fallbackRating}</p>
            <span>{stay.price || labels.fallbackPrice}</span>
          </div>
        </a>
      ))}
    </div>
    </>
  ) : (
    <a class="stay-empty-link" href={searchUrl} target="_blank" rel="sponsored nofollow noopener noreferrer">
      <strong>{labels.emptyTitle}</strong>
      <span>{labels.emptyText}</span>
    </a>
  )}
  <p class="affiliate-note">
    {labels.affiliate}
  </p>
</aside>
