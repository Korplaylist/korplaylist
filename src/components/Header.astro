---
import { regions, siteConfig } from "../site.config";

const languages = [
  { href: "/", flagImage: "/icons/flag-ko.svg", label: "한국어", code: "KO" },
  { href: "/en/", flagImage: "/icons/flag-en.svg", label: "English", code: "EN" },
  { href: "/ja/", flagImage: "/icons/flag-ja.svg", label: "日本語", code: "JA" }
];
---

<header class="site-header">
  <a class="brand" href="/" aria-label="한국플레이리스트 홈">
    <span class="brand-mark">K</span>
    <span>{siteConfig.siteName}</span>
  </a>
  <nav class="nav" aria-label="주요 메뉴">
    <a href="/regions/">지역</a>
    <a href="/categories/">테마</a>
    <a href="/about/">소개</a>
    <a href="/contact/">문의</a>
  </nav>
  <div class="header-actions">
    <div class="quick-links" aria-label="빠른 지역">
      {regions.slice(0, 4).map((region) => <a href={`/regions/${encodeURIComponent(region)}/`}>{region}</a>)}
    </div>
    <nav class="language-switcher" aria-label="언어 선택">
      {languages.map((language) => (
        <a class="language-link" href={language.href} aria-label={`${language.label} 메인 페이지로 이동`} title={language.label}>
          <img class="language-flag" src={language.flagImage} alt="" width="24" height="16" loading="lazy" />
          <span class="language-label">{language.label}</span>
          <span class="language-code">{language.code}</span>
        </a>
      ))}
    </nav>
  </div>
</header>
