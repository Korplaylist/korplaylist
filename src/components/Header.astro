---
import { localeLabels, siteConfig } from "../site.config";

const { locale = "ko" } = Astro.props;
const labels = localeLabels[locale] ?? localeLabels.ko;
const siteName = siteConfig.localizedSiteNames[locale] ?? siteConfig.siteName;

const languages = [
  { href: "/", flagImage: "/icons/flag-ko.svg", label: "한국어", code: "KO" },
  { href: "/en/", flagImage: "/icons/flag-en.svg", label: "English", code: "EN" },
  { href: "/ja/", flagImage: "/icons/flag-ja.svg", label: "日本語", code: "JA" }
];
---

<header class="site-header">
  <a class="brand" href={labels.homeHref} aria-label={labels.homeAria}>
    <img class="brand-logo" src="/brand/korplaylist-logo.png" alt="" width="38" height="38" loading="eager" decoding="async" />
    <span>{siteName}</span>
  </a>
  <nav class="nav" aria-label={labels.navLabel}>
    <a href={locale === "ko" ? "/regions/" : `/${locale}/#regions`}>{labels.regions}</a>
    <a href={locale === "ko" ? "/categories/" : `/${locale}/#themes`}>{labels.categories}</a>
    <a href={locale === "ko" ? "/about/" : `/${locale}/#about`}>{labels.about}</a>
    <a href={locale === "ko" ? "/contact/" : `/${locale}/#contact`}>{labels.contact}</a>
  </nav>
  <div class="header-actions">
    <nav class="language-switcher" aria-label={labels.languageLabel}>
      {languages.map((language) => (
        <a class="language-link" href={language.href} aria-label={`${language.label} 메인 페이지로 이동`} title={language.label}>
          <img class="language-flag" src={language.flagImage} alt="" width="24" height="16" loading="lazy" decoding="async" />
          <span class="language-label">{language.label}</span>
          <span class="language-code">{language.code}</span>
        </a>
      ))}
    </nav>
  </div>
</header>
