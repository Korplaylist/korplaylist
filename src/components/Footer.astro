---
import { localeLabels, siteConfig } from "../site.config";

const { locale = "ko" } = Astro.props;
const labels = localeLabels[locale] ?? localeLabels.ko;
const siteName = siteConfig.localizedSiteNames[locale] ?? siteConfig.siteName;
---

<footer class="site-footer">
  <div>
    <strong>{siteName}</strong>
    <p>{labels.footerText}</p>
  </div>
  <nav aria-label={labels.navLabel}>
    <a href={locale === "ko" ? "/about/" : `/${locale}/#about`}>{labels.about}</a>
    <a href="/privacy/">{labels.privacy}</a>
    <a href="/terms/">{labels.terms}</a>
    <a href={locale === "ko" ? "/contact/" : `/${locale}/#contact`}>{labels.contact}</a>
  </nav>
</footer>
