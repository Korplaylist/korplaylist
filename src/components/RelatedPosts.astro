---
import { getWebpSrcSet } from "../lib/imageVariants";
import { getImageAlt, getPostUrl } from "../lib/travel";

const { posts = [], locale = "ko" } = Astro.props;
const labels = {
  ko: {
    title: "함께 보면 좋은 글",
    description: "현재 글과 지역, 테마, 태그가 가까운 여행 가이드를 함께 확인하세요."
  },
  en: {
    title: "Related Korea travel guides",
    description: "Continue with guides that match this region, theme, or search intent."
  },
  ja: {
    title: "あわせて読みたい記事",
    description: "地域、テーマ、検索意図が近い韓国旅行ガイドを続けて確認できます。"
  }
}[locale] ?? {
  title: "함께 보면 좋은 글",
  description: "현재 글과 지역, 테마, 태그가 가까운 여행 가이드를 함께 확인하세요."
};
---

{posts.length > 0 && (
  <section class="related-panel" aria-labelledby="related-posts-title">
    <div class="section-head compact">
      <div>
        <h2 id="related-posts-title">{labels.title}</h2>
        <p>{labels.description}</p>
      </div>
    </div>
    <div class="related-grid">
      {posts.map((post) => (
        <a class="related-card" href={getPostUrl(post)}>
          <picture>
            <source type="image/webp" srcset={getWebpSrcSet(post.data.heroImage, [360, 480, 640])} sizes="(max-width: 760px) 96px, 174px" />
            <img src={post.data.heroImage} alt={getImageAlt(post)} width="360" height="220" loading="lazy" decoding="async" sizes="(max-width: 760px) 96px, 174px" />
          </picture>
          <div>
            <span>{post.data.region} · {post.data.category}</span>
            <strong>{post.data.title}</strong>
            <p>{post.data.description}</p>
          </div>
        </a>
      ))}
    </div>
  </section>
)}
