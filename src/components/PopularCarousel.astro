---
import { getWebpSrcSet } from "../lib/imageVariants";
import { formatDate, getImageAlt, getPostLocale, getPostUrl } from "../lib/travel";

const { posts = [], locale = "ko" } = Astro.props;
const labels = {
  ko: {
    title: "인기 여행 가이드",
    controls: "인기글 이동",
    prev: "이전 인기글",
    next: "다음 인기글",
    read: "자세히 보기",
    regions: "지역별 보기",
    regionsHref: "/regions/",
    readAria: "읽기"
  },
  en: {
    title: "Popular Korea Travel Guides",
    controls: "Move popular guides",
    prev: "Previous popular guide",
    next: "Next popular guide",
    read: "Read guide",
    regions: "Browse regions",
    regionsHref: "/en/#regions",
    readAria: "read"
  },
  ja: {
    title: "人気の韓国旅行ガイド",
    controls: "人気記事の移動",
    prev: "前の人気記事",
    next: "次の人気記事",
    read: "詳しく見る",
    regions: "地域を見る",
    regionsHref: "/ja/#regions",
    readAria: "を読む"
  }
}[locale] ?? {
  title: "인기 여행 가이드",
  controls: "인기글 이동",
  prev: "이전 인기글",
  next: "다음 인기글",
  read: "자세히 보기",
  regions: "지역별 보기",
  regionsHref: "/regions/",
  readAria: "읽기"
};
---

{posts.length > 0 && (
  <section class="popular-hero" aria-labelledby="popular-title">
    <div class="popular-hero-head">
      <h1 id="popular-title">{labels.title}</h1>
      <div class="carousel-controls" aria-label={labels.controls}>
        <button type="button" data-carousel-prev aria-label={labels.prev}>‹</button>
        <button type="button" data-carousel-next aria-label={labels.next}>›</button>
      </div>
    </div>
    <div class="popular-hero-rail" data-popular-rail>
      {posts.map((post, index) => (
        <article class="popular-slide">
          <div class="popular-slide-copy">
            <p class="eyebrow">{post.data.region} · {post.data.category} · {formatDate(post.data.updatedAt, getPostLocale(post))}</p>
            <h2><a href={getPostUrl(post)}>{post.data.title}</a></h2>
            <p>{post.data.description}</p>
            <div class="hero-actions">
              <a class="button" href={getPostUrl(post)}>{labels.read}</a>
              <a class="button secondary" href={labels.regionsHref}>{labels.regions}</a>
            </div>
          </div>
          <a class="popular-slide-image" href={getPostUrl(post)} aria-label={`${post.data.title} ${labels.readAria}`}>
            <picture>
              <source type="image/webp" srcset={getWebpSrcSet(post.data.heroImage)} sizes="(max-width: 760px) calc(100vw - 36px), 48vw" />
              <img
                src={post.data.heroImage}
                alt={getImageAlt(post)}
                width="1200"
                height="760"
                loading={index === 0 ? "eager" : "lazy"}
                decoding="async"
                fetchpriority={index === 0 ? "high" : "auto"}
                sizes="(max-width: 760px) calc(100vw - 36px), 48vw"
              />
            </picture>
          </a>
        </article>
      ))}
    </div>
  </section>
)}

<script>
  const rail = document.querySelector("[data-popular-rail]");
  const prev = document.querySelector("[data-carousel-prev]");
  const next = document.querySelector("[data-carousel-next]");

  function scrollPopular(direction) {
    if (!rail) return;
    const amount = Math.max(280, rail.clientWidth * 0.82);
    rail.scrollBy({ left: direction * amount, behavior: "smooth" });
  }

  prev?.addEventListener("click", () => scrollPopular(-1));
  next?.addEventListener("click", () => scrollPopular(1));
</script>
