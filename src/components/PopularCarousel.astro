---
import { formatDate, getImageAlt, getPostUrl } from "../lib/travel";

const { posts = [] } = Astro.props;
---

{posts.length > 0 && (
  <section class="popular-hero" aria-labelledby="popular-title">
    <div class="popular-hero-head">
      <h1 id="popular-title">인기 여행 가이드</h1>
      <div class="carousel-controls" aria-label="인기글 이동">
        <button type="button" data-carousel-prev aria-label="이전 인기글">‹</button>
        <button type="button" data-carousel-next aria-label="다음 인기글">›</button>
      </div>
    </div>
    <div class="popular-hero-rail" data-popular-rail>
      {posts.map((post) => (
        <article class="popular-slide">
          <div class="popular-slide-copy">
            <p class="eyebrow">{post.data.region} · {post.data.category} · {formatDate(post.data.updatedAt)}</p>
            <h2><a href={getPostUrl(post)}>{post.data.title}</a></h2>
            <p>{post.data.description}</p>
            <div class="hero-actions">
              <a class="button" href={getPostUrl(post)}>자세히 보기</a>
              <a class="button secondary" href="/regions/">지역별 보기</a>
            </div>
          </div>
          <a class="popular-slide-image" href={getPostUrl(post)} aria-label={`${post.data.title} 읽기`}>
            <img src={post.data.heroImage} alt={getImageAlt(post)} width="1200" height="760" loading="eager" />
          </a>
        </article>
      ))}
    </div>
  </section>
)}

<script>
  const rail = document.querySelector("[data-popular-rail]");
  const prev = document.querySelector("[data-carousel-prev]");
  const next = document.querySelector("[data-carousel-next]");

  function scrollPopular(direction) {
    if (!rail) return;
    const amount = Math.max(280, rail.clientWidth * 0.82);
    rail.scrollBy({ left: direction * amount, behavior: "smooth" });
  }

  prev?.addEventListener("click", () => scrollPopular(-1));
  next?.addEventListener("click", () => scrollPopular(1));
</script>
